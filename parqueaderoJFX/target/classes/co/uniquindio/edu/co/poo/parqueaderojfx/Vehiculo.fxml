<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="760.0" prefWidth="1050.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.uniquindio.edu.co.poo.parqueaderojfx.viewController.VehiculoViewController">

    <children>

        <SplitPane dividerPositions="0.52"
                   orientation="VERTICAL"
                   prefHeight="760.0"
                   prefWidth="1050.0">

            <items>

                <!-- PANEL SUPERIOR -->
                <AnchorPane prefHeight="380.0" prefWidth="1050.0">

                    <children>

                        <Pane layoutX="25.0" layoutY="15.0"
                              prefHeight="360.0"
                              prefWidth="1000.0"
                              style="-fx-border-color: #07912c; -fx-border-width: 2; -fx-background-color: #f8f8f8;">

                            <effect>
                                <Blend />
                            </effect>

                            <children>

                                <Label layoutX="430.0" layoutY="15.0" text="Gestión Vehículos">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>

                                <!-- COLUMNA IZQUIERDA -->
                                <Label layoutX="60.0" layoutY="70.0" text="Placa:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <TextField fx:id="txtPlaca"
                                           layoutX="230.0"
                                           layoutY="66.0"
                                           prefWidth="220.0" />

                                <Label layoutX="60.0" layoutY="115.0" text="Nombre conductor:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <TextField fx:id="txtNombreConductor"
                                           layoutX="230.0"
                                           layoutY="111.0"
                                           prefWidth="220.0" />

                                <Label layoutX="60.0" layoutY="160.0" text="Identificación:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <TextField fx:id="txtIdentificacionConductor"
                                           layoutX="230.0"
                                           layoutY="156.0"
                                           prefWidth="220.0" />

                                <Label layoutX="60.0" layoutY="205.0" text="Tipo vehículo:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <ComboBox fx:id="cbTipoVehiculo"
                                          layoutX="230.0"
                                          layoutY="201.0"
                                          prefWidth="220.0" />

                                <!-- COLUMNA DERECHA -->
                                <Label layoutX="560.0" layoutY="70.0" text="Hora ingreso:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <TextField fx:id="txtHoraIngreso"
                                           layoutX="720.0"
                                           layoutY="66.0"
                                           prefWidth="220.0"
                                           promptText="HH:mm" />

                                <Label layoutX="560.0" layoutY="115.0" text="Fecha ingreso:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <DatePicker fx:id="dateFechaIngreso"
                                            layoutX="720.0"
                                            layoutY="111.0"
                                            prefWidth="220.0" />

                                <Label layoutX="560.0" layoutY="160.0" text="Hora salida:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <TextField fx:id="txtHoraSalida"
                                           layoutX="720.0"
                                           layoutY="156.0"
                                           prefWidth="220.0"
                                           promptText="HH:mm" />

                                <Label layoutX="560.0" layoutY="205.0" text="Fecha salida:">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>

                                <DatePicker fx:id="dateFechaSalida"
                                            layoutX="720.0"
                                            layoutY="201.0"
                                            prefWidth="220.0" />

                                <!-- BOTONES PRINCIPALES -->
                                <Button fx:id="btnAgregarVehiculo"
                                        layoutX="290.0"
                                        layoutY="290.0"
                                        mnemonicParsing="false"
                                        onAction="#onAgregarVehiculo"
                                        prefWidth="180.0"
                                        text="Registrar Entrada" />

                                <Button fx:id="btnRegistrarSalida"
                                        layoutX="540.0"
                                        layoutY="290.0"
                                        mnemonicParsing="false"
                                        onAction="#onRegistrarSalida"
                                        prefWidth="180.0"
                                        text="Registrar Salida" />

                            </children>
                        </Pane>

                    </children>
                </AnchorPane>

                <!-- PANEL INFERIOR -->
                <AnchorPane prefHeight="360.0" prefWidth="1050.0">

                    <children>

                        <TableView fx:id="tblListVehiculo"
                                   layoutX="10.0"
                                   layoutY="10.0"
                                   prefHeight="285.0"
                                   prefWidth="1030.0">

                            <columns>
                                <TableColumn fx:id="tbcPlaca" prefWidth="120.0" text="Placa" />
                                <TableColumn fx:id="tbcNombreConductor" prefWidth="190.0" text="Conductor" />
                                <TableColumn fx:id="tbcIdentificacionConductor" prefWidth="150.0" text="Identificación" />
                                <TableColumn fx:id="tbcHoraIngreso" prefWidth="160.0" text="Hora ingreso" />
                                <TableColumn fx:id="tbcHoraSalida" prefWidth="160.0" text="Hora salida" />
                                <TableColumn fx:id="tbcTipoVehiculo" prefWidth="120.0" text="Tipo" />
                                <TableColumn fx:id="tbcEstadoVehiculo" prefWidth="120.0" text="Estado" />
                            </columns>

                        </TableView>

                        <Button fx:id="btnRegresar"
                                layoutX="390.0"
                                layoutY="315.0"
                                mnemonicParsing="false"
                                onAction="#onRegresar"
                                prefWidth="120.0"
                                text="Regresar" />

                        <Button fx:id="btnLimpiar"
                                layoutX="540.0"
                                layoutY="315.0"
                                mnemonicParsing="false"
                                onAction="#onLimpiar"
                                prefWidth="120.0"
                                text="Limpiar" />

                    </children>

                </AnchorPane>

            </items>

        </SplitPane>

    </children>

</AnchorPane>
