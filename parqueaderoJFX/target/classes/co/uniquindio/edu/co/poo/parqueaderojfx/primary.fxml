<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #f5fff7; -fx-border-color: green; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.uniquindio.edu.co.poo.parqueaderojfx.viewController.PrimaryViewController">

    <padding>
        <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
    </padding>

    <children>

        <Label text="ParqueaUQ">
            <font>
                <Font name="Arial Bold" size="30.0" />
            </font>
        </Label>

        <Label maxWidth="500" text="Bienvenidos al sistema de parqueadero de la Universidad del Quindío" textAlignment="CENTER" wrapText="true">

            <font>
                <Font size="16.0" />
            </font>

        </Label>

        <Label fx:id="welcomeText" />

        <Button onAction="#onOpenOpcionesParqueadero" prefHeight="40" prefWidth="180" style="-fx-background-color: #07912c;                        -fx-text-fill: white;                        -fx-font-size: 14px;                        -fx-font-weight: bold;" text="Entrar " />

    </children>
</VBox>
