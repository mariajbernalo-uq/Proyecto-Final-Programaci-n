<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER"
      spacing="20"
      style="-fx-background-color:#f5fff7;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.uniquindio.edu.co.poo.parqueaderojfx.viewController.UniversidadViewController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <children>

        <Label text="Reportes del Parqueadero">
            <font>
                <Font name="System Bold" size="22" />
            </font>
        </Label>

        <TextArea fx:id="txtAreaReportes"
                  editable="false"
                  prefHeight="350"
                  prefWidth="600" />

        <!-- CONSULTA POR HORAS -->
        <HBox alignment="CENTER" spacing="10">

            <Label text="Horas:" />

            <TextField fx:id="txtHoras"
                       promptText="Ejemplo: 5" />

            <Button text="Consultar Vehículos por Horas"
                    onAction="#onConsultarVehiculosHoras" />

        </HBox>

        <!-- BOTONES PRINCIPALES -->
        <HBox alignment="CENTER" spacing="15">

            <!-- BOTON GENERAR REPORTE GENERAL -->
            <Button onAction="#onGenerarReporteGeneral"
                    text="Reporte General" />

            <!-- BOTON CONSULTAR ESTADO ESPACIOS -->
            <Button onAction="#onConsultarEstadoEspacios"
                    text="Estado Espacios" />

            <!-- BOTON CONSULTAR VEHICULOS ESTACIONADOS -->
            <Button onAction="#onConsultarVehiculos"
                    text="Vehículos Parqueados" />

            <!-- BOTON CONSULTAR INGRESOS DIARIOS -->
            <Button onAction="#onCalcularIngresosDiarios"
                    text="Ingresos Diarios" />

            <!-- BOTON TIEMPO PROMEDIO -->
            <Button onAction="#onCalcularTiempoPermanencia"
                    text="Tiempo Promedio de Permanencia" />

            <!-- BOTON REGRESAR -->
            <Button onAction="#onRegresar"
                    text="Regresar" />

        </HBox>

    </children>
</VBox>
