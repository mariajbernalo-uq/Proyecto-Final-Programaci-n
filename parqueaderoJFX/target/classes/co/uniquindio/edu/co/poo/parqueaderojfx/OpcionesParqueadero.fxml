<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="309.0" prefWidth="427.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.uniquindio.edu.co.poo.parqueaderojfx.viewController.OpcionesParqueaderoViewController">
    <padding>
        <Insets bottom="30.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Label text="Bienvenidos al sistema de parqueadero de la UQ" textAlignment="CENTER" textFill="#07912c" wrapText="true">
      <font>
         <Font name="System Bold" size="18.0" />
      </font></Label>

    <Label fx:id="welcomeText" />
   <GridPane alignment="TOP_CENTER" hgap="15.0" vgap="15.0">
     <columnConstraints>
       <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
       <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
     </columnConstraints>
     <rowConstraints>
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
     </rowConstraints>
      <children>
         <Button mnemonicParsing="false" onAction="#openInterfazVehiculo" text="Vehículo" textAlignment="CENTER" GridPane.halignment="CENTER" GridPane.valignment="CENTER" />
         <Button fx:id="openInterfazVehiculo" layoutX="48.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazUsuario" text="Usuario" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.halignment="CENTER" />
         <Button fx:id="btnInterfazTarifa" layoutX="176.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazTarifa" text="Tarifa" textAlignment="CENTER" GridPane.halignment="CENTER" GridPane.rowIndex="1" />
         <Button fx:id="btnInterfazEspacioParqueadero" layoutX="11.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazEspacioParqueadero" text="EspacioParqueadero" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1" />
         <Button fx:id="btnInterfazUniversidad" layoutX="44.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazuniversidad" text="Reportes" textAlignment="CENTER" GridPane.halignment="CENTER" GridPane.rowIndex="2" />
         <Button fx:id="btnInterfazprimary" layoutX="44.0" layoutY="104.0" mnemonicParsing="false" onAction="#openInterfazPrimary" text="Salir" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="2" />
      </children>
   </GridPane>
</VBox>
