<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #f4f4f#dfffe74;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.uniquindio.edu.co.poo.parqueaderojfx.viewController.UniversidadViewController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <children>

        <Label text="Reportes del Parqueadero">
            <font>
                <Font name="System Bold" size="22" />
            </font>
        </Label>

        <TextArea fx:id="txtAreaReportes" editable="false" prefHeight="350" prefWidth="600" style="-fx-background-color: #dfffe7;" wrapText="true" />

        <HBox alignment="CENTER" spacing="15">

            <Button onAction="#onConsultarEstadoEspacios" text="Estado Espacios" />

            <Button onAction="#onConsultarVehiculos" text="Vehículos Parqueados" />

            <Button onAction="#onVolver" text="Volver" />

        </HBox>

    </children>
</VBox>
