<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="383.0" prefWidth="587.0" style="-fx-background-color: #f5fff7; -fx-border-color: green; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.uniquindio.edu.co.poo.parqueaderojfx.viewController.OpcionesParqueaderoViewController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>
    <Label text="Bienvenidos al sistema de parqueadero de la UQ" textAlignment="CENTER" textFill="#04661d" wrapText="true">
      <font>
         <Font name="System Bold" size="18.0" />
      </font></Label>

    <Label fx:id="textoInicial" />
   <GridPane alignment="TOP_CENTER" hgap="15.0" vgap="15.0">
     <columnConstraints>
       <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
       <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
     </columnConstraints>
     <rowConstraints>
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
     </rowConstraints>
      <children>
         <Button contentDisplay="CENTER" mnemonicParsing="false" onAction="#openInterfazVehiculo" text="Vehículo" textAlignment="JUSTIFY" GridPane.halignment="CENTER">
            <font>
               <Font name="Segoe UI" size="14.0" />
            </font></Button>
         <Button fx:id="openInterfazVehiculo" layoutX="48.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazUsuario" text="Usuario" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.halignment="CENTER">
            <font>
               <Font name="Segoe UI" size="14.0" />
            </font></Button>
         <Button fx:id="btnInterfazTarifa" layoutX="176.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazTarifa" text="Tarifa" textAlignment="CENTER" GridPane.halignment="CENTER" GridPane.rowIndex="1">
            <font>
               <Font name="Segoe UI" size="14.0" />
            </font></Button>
         <Button fx:id="btnInterfazEspacioParqueadero" layoutX="11.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazEspacioParqueadero" text="EspacioParqueadero" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1">
            <font>
               <Font name="Segoe UI" size="14.0" />
            </font></Button>
         <Button fx:id="btnInterfazUniversidad" layoutX="44.0" layoutY="12.0" mnemonicParsing="false" onAction="#openInterfazuniversidad" text="Reportes" textAlignment="CENTER" GridPane.halignment="CENTER" GridPane.rowIndex="2">
            <font>
               <Font size="14.0" />
            </font></Button>
         <Button fx:id="btnSalir" layoutX="44.0" layoutY="104.0" mnemonicParsing="false" onAction="#salirAplicacion" text="Salir" textAlignment="CENTER" textFill="#3e40b1" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="2">
            <font>
               <Font name="System Bold" size="13.0" />
            </font></Button>
      </children>
   </GridPane>
</VBox>
