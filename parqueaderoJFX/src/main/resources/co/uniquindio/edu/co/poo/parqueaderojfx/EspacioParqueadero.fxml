                                <TableColumn fx:id="tbcTipoVehiculo" prefWidth="180.0" text="Tipo Vehículo" />

                                <TableColumn fx:id="tbcEstadoEspacio" prefWidth="180.0" text="Estado" />

                                <TableColumn fx:id="tbcVehiculoAsignado" prefWidth="135.0" text="Vehículo" />
