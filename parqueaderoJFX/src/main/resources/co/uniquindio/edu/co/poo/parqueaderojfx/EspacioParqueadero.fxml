                                    </font>
                                </Label>

                                <TextField fx:id="txtCodigo" layoutX="180.0" layoutY="65.0" prefWidth="220.0" />

                                <Label layoutX="45.0" layoutY="110.0" text="Tipo Vehículo:">
                                    <font>
